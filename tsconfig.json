{
  "compilerOptions": {
    "module": "nodenext",
    "esModuleInterop": true,
    "target": "es2020",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "noUnusedLocals": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "allowJs": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": ["src/@types", "node_modules/@types"],
  },
  "include": [
    "./src/**/*.ts", "./tests/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
