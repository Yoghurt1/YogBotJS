{
  "compilerOptions": {
    "module": "nodenext",
    "esModuleInterop": true,
    "target": "es2020",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "noUnusedLocals": true,
    "forceConsistentCasingInFileNames": true,
    "types": [],
    "allowJs": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "./src/**/*.ts", "src/index.tsx",
  ],
  "exclude": [
    "node_modules"
  ]
}
