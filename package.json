  },
  "homepage": "https://github.com/Yoghurt1/YogBotJS#readme",
  "dependencies": {
    "@aws-sdk/client-sns": "^3.864.0",
    "axios": "^1.11.0",
    "discord.js": "^14.21.0",
    "http-status-codes": "^2.3.0",
    "inversify": "6.2.1",
    "luxon": "^3.7.1",
    "mqtt": "^5.14.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.1",
    "reflect-metadata": "^0.2.2",
    "smithy": "^0.6.3"
  },
