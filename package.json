    "@types/luxon": "^3.7.1",
    "@types/mocha": "^10.0.10",
    "@types/pino": "^7.0.4",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.4",
    "chai": "^6.0.1",
    "eslint": "^9.32.0",
    "eslint-plugin-jsdoc": "^54.1.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "mocha": "^11.7.2",
    "nodemon": "^3.1.10",
    "proxyquire": "^2.1.3",
    "rimraf": "^6.0.1",
    "sinon": "^21.0.0",
